                },
                {
                  "text": "Now jump and check again",
                  "hint": "现在跳一跳再检查一次",
                  "emoji": "🦘",
                  "imageUrl": "https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=400&h=400&fit=crop&auto=format&q=80"
                }
