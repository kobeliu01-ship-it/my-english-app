              "labelEn": "Feelings",
              "color": "purple",
              "items": [
                {
                  "text": "Calm",
                  "hint": "平静",
                  "emoji": "😌",
                  "imageUrl": "https://images.unsplash.com/photo-1506126613408-eca07ce68773?w=400&h=400&fit=crop&auto=format&q=80"
                },
                {
                  "text": "Refreshed",
                  "hint": "神清气爽",
