              ]
            },
            {
              "id": "sentences",
              "label": "句型",
              "labelEn": "Sentences",
              "color": "green",
              "items": [
                {
                  "text": "My heart beats faster because I was running.",
                  "hint": "我的心跳加快，因为我刚才在跑步。",
                  "emoji": "❤️",
                  "imageUrl": "https://images.unsplash.com/photo-1559757175-5700dde675bc?w=400&h=400&fit=crop&auto=format&q=80"
                },
                {
                  "text": "If your heart is beating, you are alive!",
