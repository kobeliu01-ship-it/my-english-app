              "id": "feelings",
              "label": "感受",
              "labelEn": "Feelings",
              "color": "purple",
              "items": [
                {
                  "text": "Curious",
                  "hint": "好奇",
                  "emoji": "🤔",
                  "imageUrl": "https://images.unsplash.com/photo-1532187863486-abf9dbad1b69?w=400&h=400&fit=crop&auto=format&q=80"
                },
                {
                  "text": "Amazed",
                  "hint": "惊叹",
