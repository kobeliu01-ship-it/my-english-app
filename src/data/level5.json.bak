                {
                  "text": "Strong",
                  "hint": "强壮",
                  "emoji": "💪",
                  "imageUrl": "https://images.unsplash.com/photo-1518611012118-696072aa579a?w=400&h=400&fit=crop&auto=format&q=80"
                }
