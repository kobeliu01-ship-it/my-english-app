              "label": "句型",
              "labelEn": "Sentences",
              "color": "green",
              "items": [
                {
                  "text": "When you breathe in, your lungs fill with air.",
                  "hint": "当你吸气时，你的肺里充满了空气。",
                  "emoji": "🫁",
